{
  "manifest_version": 3,
  "name": "Human Auto Typing",
  "version": "1.0.0",
  "description": "Simulates natural human typing with variable rhythm, pauses, nearby-key typos, and auto-correction.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Human Auto Typing",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "lib/key-events.js",
        "lib/human-model.js",
        "lib/typing-engine.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
